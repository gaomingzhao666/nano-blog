---
import { siteConfig } from '@/site-config'
import path from 'node:path'
import { AstroFont } from 'astro-font'

export interface Props {
  title: string
  description?: string
  ogImage?: string | undefined
  articleDate?: string | undefined
}

const {
  title,
  description = siteConfig.description,
  ogImage,
  articleDate,
}: Props = Astro.props

const canonicalHref =
  Astro.site != null
    ? new URL(Astro.url.pathname, Astro.site).href
    : Astro.url.href
const socialImageHref = new URL(
  ogImage ?? '/open-graph.png',
  Astro.url,
).href

const titleSeparator = '•'

const siteTitle = `${title} ${titleSeparator} ${siteConfig.title}`

const fontPath = (fileName: string) =>
  path.resolve(import.meta.dirname, '../../public/fonts', fileName)
---

<meta http-equiv="refresh" content="no data" id="redirectMeta" />

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/svg+xml" href="/favicon.ico" />
<meta name="generator" content={Astro.generator} />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalHref} />

<!-- Primary Meta Tags -->
<title>{siteTitle}</title>

<!-- SEO -->
<meta name="title" content={siteTitle} />
<meta name="description" content={description} />
<meta name="author" content={siteConfig.author} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={articleDate ? 'article' : 'website'} />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={socialImageHref} />
{
  articleDate && (
    <>
      <meta property="article:author" content={siteConfig.author} />
      <meta property="article:published_time" content={articleDate} />
    </>
  )
}

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={socialImageHref} />

<!-- Sitemap -->
<link rel="sitemap" href="/sitemap-index.xml" />

<!-- RSS auto-discovery -->
<link
  rel="alternate"
  type="application/rss+xml"
  title={siteConfig.title}
  href="/rss.xml"
/>

<AstroFont
  config={[
    {
      preload: false,
      display: 'swap',
      name: 'Manrope',
      fallback: 'sans-serif',
      src: [
        {
          weight: '200',
          style: 'normal',
          path: fontPath('Manrope-ExtraLight.woff2'),
        },
        {
          weight: '300',
          style: 'normal',
          path: fontPath('Manrope-Light.woff2'),
        },
        {
          weight: '400',
          style: 'normal',
          path: fontPath('Manrope-Regular.woff2'),
        },
        {
          weight: '500',
          style: 'normal',
          path: fontPath('Manrope-Medium.woff2'),
        },
        {
          weight: '600',
          style: 'normal',
          path: fontPath('Manrope-SemiBold.woff2'),
        },
        {
          weight: '700',
          preload: true,
          style: 'normal',
          path: fontPath('Manrope-Bold.woff2'),
        },
        {
          weight: '800',
          style: 'normal',
          path: fontPath('Manrope-ExtraBold.woff2'),
        },
      ],
    },
  ]}
/>

<script>
  const initLang = () => {
    const redirectMeta = document.querySelector('#redirectMeta')
    const currentLang = localStorage.getItem('lang')

    if (!redirectMeta || !currentLang || currentLang === 'en') return
    redirectMeta.setAttribute('content', `0; url=/${currentLang}`)
  }

  // which means, lock == '1' equals locked, and lock == undefined equals not locked
  const lock = () => sessionStorage.setItem('lock', '1')
  const isLocked = () => Boolean(sessionStorage.getItem('lock'))

  // only effect on first load
  window.addEventListener('DOMContentLoaded', () => {
    if (!isLocked()) {
      initLang()
      lock()
    }
  })
</script>
